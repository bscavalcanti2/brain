# Database connection (Supabase with pgbouncer)
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?pgbouncer=true"

# Direct connection (bypasses pooler for migrations)
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# API key for authenticating requests
BRAIN_API_KEY="sk-brain-[random-32-chars]"

# OpenAI API key (for semantic search embeddings)
# Optional — semantic/hybrid search will fall back to full-text if not set
OPENAI_API_KEY="sk-[your-openai-key]"

# Public app URL (for Vercel deployment)
NEXT_PUBLIC_APP_URL="https://brain-bruno.vercel.app"
