# Database connection (Supabase with pgbouncer)
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?pgbouncer=true"

# Direct connection (bypasses pooler for migrations)
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# API key for authenticating requests
BRAIN_API_KEY="sk-brain-[random-32-chars]"

# Zhipu API key for embeddings (production / Vercel)
# Get it from https://open.bigmodel.cn — format: "{id}.{secret}"
# Optional for local dev (uses AutoGLM token service), REQUIRED for production
ZHIPU_API_KEY=""

# Public app URL (for Vercel deployment)
NEXT_PUBLIC_APP_URL="https://brain-bruno.vercel.app"

# Note: Embeddings use Zhipu embedding-3 model.
# Local dev: auto-fetches token via AutoGLM service (no config needed)
# Production: uses ZHIPU_API_KEY to generate JWT at runtime
